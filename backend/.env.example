# Copy the exact strings from Supabase Dashboard -> Connect -> URI tab.
# Pooled (6543) and direct (5432) use DIFFERENT hosts and usernames — don't
# hand-construct these, copy-paste them.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"
JWT_SECRET="change-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:5173"]

# Base URL of the running frontend — used to build the link inside
# password-reset emails (e.g. "{FRONTEND_URL}/reset-password?token=...").
FRONTEND_URL="http://localhost:5173"

# Governance Copilot — get a free-tier key from https://aistudio.google.com/apikey
GEMINI_API_KEY="..."

# Sends the forgot/reset-password email. Any SMTP provider works; for Gmail
# you MUST use an App Password (Google Account -> Security -> 2-Step
# Verification -> App passwords), not your normal account password — Gmail
# rejects plain SMTP auth otherwise.
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
SENDER_EMAIL="your-address@gmail.com"
SENDER_EMAIL_PW="your-16-char-app-password"
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
