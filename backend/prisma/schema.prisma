generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum AiToolRiskTier {
  APPROVED
  RESTRICTED
  BLOCKED
}

enum SessionStatus {
  ACTIVE
  ENDED
}

enum PromptStatus {
  FORWARDED
  BLOCKED
  SANITIZED
  PENDING_APPROVAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RuleAction {
  ALLOW
  WARN
  BLOCK
  SANITIZE
  REQUIRE_APPROVAL
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AlertStatus {
  OPEN
  REVIEWING
  RESOLVED
  ESCALATED
}

enum AppealSourceType {
  PROMPT_BLOCK
  TOOL_REJECTION
  RISK_ALERT
}

enum AppealStatus {
  PENDING
  UNDER_REVIEW
  AWAITING_INFO
  RESOLVED
}

enum AppealResolution {
  UPHELD
  OVERTURNED
}

enum RecommendationStatus {
  PENDING
  ACCEPTED
  MODIFIED
  REJECTED
}

enum CopilotRole {
  USER
  COPILOT
}

enum ScanTrigger {
  MANUAL
  SCHEDULED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  department   String
  role         Role     @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approvedTools           AiTool[]
  trustEvaluations        AiTrustEvaluation[]
  sessions                AiSession[]
  toolRequestsSubmitted   AiToolRequest[]        @relation("RequestSubmittedBy")
  toolRequestsReviewed    AiToolRequest[]        @relation("RequestReviewedBy")
  riskAlerts              RiskAlert[]
  auditLogs               AuditLog[]
  appealsFiled            Appeal[]               @relation("AppealFiledBy")
  appealsReviewed         Appeal[]               @relation("AppealReviewedBy")
  notifications           Notification[]
  sensitiveDataRules      SensitiveDataRule[]
  useCasePolicies         UseCasePolicy[]
  toolTierPolicies        ToolTierPolicy[]
  policiesCreated         Policy[]
  recommendationsReviewed PolicyRecommendation[]
  governanceCopilotSessions GovernanceCopilotSession[]
  usageScansTriggered     AiToolUsageScan[]

  @@map("users")
}

model AiTool {
  id           String         @id @default(uuid())
  name         String         @unique
  vendor       String
  version      String?
  endpoint     String?
  description  String?
  riskTier     AiToolRiskTier @default(RESTRICTED)
  isApproved   Boolean        @default(false)
  approvedById String?
  approvedBy   User?          @relation(fields: [approvedById], references: [id])
  approvedAt   DateTime?
  // Human-readable rationale for the tool's current riskTier decision — set
  // when a trust evaluation is approved or rejected. Reused to immediately
  // resolve later duplicate AiToolRequests for the same tool name without
  // requiring a fresh evaluation.
  decisionNotes String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  trustEvaluations  AiTrustEvaluation[]
  sessions          AiSession[]
  fulfilledRequests AiToolRequest[]
  usageScans        AiToolUsageScan[]
  tierPolicies      ToolTierPolicy[]

  @@map("ai_tools")
}

// A periodic (or on-demand) scan of a tool's REAL logged usage — block rate
// and sensitive-data match rate computed directly from Prompt/PromptRiskFinding
// rows, not re-asking an LLM to re-score the tool's static description. Drift
// is flagged by comparing this scan's rates against the tool's previous scan.
// aiSummary is only populated (via Gemini, over a sample of this tool's own
// flagged transcripts) when a scan is flagged — a qualitative annotation on
// top of a metrics-triggered alert, not the trigger itself.
model AiToolUsageScan {
  id                     String      @id @default(uuid())
  aiToolId               String
  aiTool                 AiTool      @relation(fields: [aiToolId], references: [id])
  windowStart            DateTime
  windowEnd              DateTime
  promptCount            Int
  blockRate              Float
  sensitiveDataMatchRate Float
  isDriftFlagged         Boolean     @default(false)
  aiSummary              String?
  triggeredBy            ScanTrigger
  triggeredById          String?
  triggeredByUser        User?       @relation(fields: [triggeredById], references: [id])
  scannedAt              DateTime    @default(now())

  @@map("ai_tool_usage_scans")
}

model AiTrustEvaluation {
  id                   String   @id @default(uuid())
  aiToolId             String
  aiTool               AiTool   @relation(fields: [aiToolId], references: [id])
  securityScore        Int
  securityReason       String?
  privacyScore         Int
  privacyReason        String?
  complianceScore      Int
  complianceReason     String?
  availabilityScore    Int
  availabilityReason   String?
  explainabilityScore  Int
  explainabilityReason String?
  orgPolicyScore       Int
  orgPolicyReason      String?
  overallScore         Int
  justification        String?
  evaluatedById        String
  evaluatedBy          User     @relation(fields: [evaluatedById], references: [id])
  evaluatedAt          DateTime @default(now())

  @@map("ai_trust_evaluations")
}

model AiSession {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  aiToolId  String
  aiTool    AiTool        @relation(fields: [aiToolId], references: [id])
  status    SessionStatus @default(ACTIVE)
  startedAt DateTime      @default(now())
  endedAt   DateTime?

  prompts Prompt[]

  @@map("ai_sessions")
}

model Prompt {
  id                    String       @id @default(uuid())
  sessionId             String
  session               AiSession    @relation(fields: [sessionId], references: [id])
  promptText            String
  sanitizedText         String?
  containsSensitiveData Boolean      @default(false)
  status                PromptStatus @default(FORWARDED)
  createdAt             DateTime     @default(now())

  riskFindings PromptRiskFinding[]
  response     AiResponse?
  riskAlerts   RiskAlert[]

  @@map("prompts")
}

model PromptRiskFinding {
  id        String             @id @default(uuid())
  promptId  String
  prompt    Prompt             @relation(fields: [promptId], references: [id])
  ruleId    String?
  rule      SensitiveDataRule? @relation(fields: [ruleId], references: [id])
  category  String
  riskLevel RiskLevel
  note      String?

  @@map("prompt_risk_findings")
}

model AiResponse {
  id             String   @id @default(uuid())
  promptId       String   @unique
  prompt         Prompt   @relation(fields: [promptId], references: [id])
  responseText   String
  responseTimeMs Int?
  tokenUsage     Int?
  createdAt      DateTime @default(now())

  @@map("ai_responses")
}

model SensitiveDataRule {
  id          String     @id @default(uuid())
  category    String
  riskLevel   RiskLevel
  action      RuleAction
  isActive    Boolean    @default(true)
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())

  findings PromptRiskFinding[]

  @@map("sensitive_data_rules")
}

// Governs what an AI is allowed to *decide*, not what data it can see —
// SensitiveDataRule restricts data categories, this restricts use cases
// (e.g. "Hiring Decisions" -> REQUIRE_APPROVAL) regardless of whether the
// prompt contains any sensitive data at all. useCase is matched against the
// fixed vocabulary intent_service.py classifies prompts into; minConfidence
// guards against a low-confidence classification triggering enforcement on
// an ordinary prompt that merely brushes against a governed topic.
model UseCasePolicy {
  id            String     @id @default(uuid())
  useCase       String
  // Admin-authored context for the intent classifier — since useCase is now
  // a free-text label rather than a fixed enum, this is what gives Gemini
  // enough signal to recognize the category from a prompt (e.g. useCase
  // "Employee Monitoring" alone is ambiguous; the description can specify
  // "without the employee's knowledge or consent").
  description   String?
  riskLevel     RiskLevel
  action        RuleAction
  minConfidence Int        @default(70)
  isActive      Boolean    @default(true)
  createdById   String
  createdBy     User       @relation(fields: [createdById], references: [id])
  createdAt     DateTime   @default(now())

  @@map("use_case_policies")
}

// The matrix Challenge 2 needs and the flat AiTool.riskTier gate in
// prompt_service doesn't provide on its own: what a given tool *tier* is
// allowed to receive, broken down by data category. A RESTRICTED tool no
// longer means "blocked outright" — it means "subject to these per-category
// rules", so e.g. small-talk can still go to a RESTRICTED tool while
// "credential" or "source code" categories still get BLOCKed for that tier.
// category free-text matches the same vocabulary as SensitiveDataRule.category
// (both ultimately compared against detection_service's category matches).
//
// aiToolId is optional: null means "applies to every tool in this tier"
// (the class-level rule); set means "applies to this one tool specifically",
// overriding the tier-level rule for that tool/category pair — e.g. carve
// out "ChatGPT can't receive source code" even though other RESTRICTED tools
// can, per a tier-level rule that allows it.
model ToolTierPolicy {
  id          String         @id @default(uuid())
  toolTier    AiToolRiskTier
  aiToolId    String?
  aiTool      AiTool?        @relation(fields: [aiToolId], references: [id])
  category    String
  riskLevel   RiskLevel
  action      RuleAction
  isActive    Boolean        @default(true)
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  @@map("tool_tier_policies")
}

model Policy {
  id                  String   @id @default(uuid())
  name                String
  description         String?
  severity            String
  appliesToDepartment String?
  isActive            Boolean  @default(true)
  createdById         String
  createdBy           User     @relation(fields: [createdById], references: [id])
  createdAt           DateTime @default(now())

  @@map("policies")
}

model AiToolRequest {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation("RequestSubmittedBy", fields: [userId], references: [id])
  toolName        String
  businessReason  String
  department      String
  // What categories of organizational data this tool will actually touch,
  // declared by the requester at intake — not free text, so it can drive
  // triage and feed the AI evaluation as real context instead of the
  // evaluator having to guess from the tool name alone.
  dataCategories  String[]      @default([])
  status          RequestStatus @default(PENDING)
  rejectionReason String?
  approvedToolId  String?
  approvedTool    AiTool?       @relation(fields: [approvedToolId], references: [id])
  reviewedById    String?
  reviewedBy      User?         @relation("RequestReviewedBy", fields: [reviewedById], references: [id])
  submittedAt     DateTime      @default(now())
  reviewedAt      DateTime?
  // Set at intake so "days not months" is something the system holds
  // itself to, not just an aspiration — mirrors Appeal.slaDeadline.
  slaDeadline     DateTime?

  @@map("ai_tool_requests")
}

model RiskAlert {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  promptId    String?
  prompt      Prompt?     @relation(fields: [promptId], references: [id])
  alertType   String
  severity    String
  description String?
  status      AlertStatus @default(OPEN)
  createdAt   DateTime    @default(now())

  @@map("risk_alerts")
}

model AuditLog {
  id         String   @id @default(uuid())
  // Nullable so a failed login against an email with no matching account can
  // still be logged (there's no user row to attach it to) — entityId carries
  // the attempted email in that case instead of a real entity's id.
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  // JSON snapshot of the entity's detail fields, captured at deletion time
  // only — once a row is deleted there's nothing left to look up live for
  // the "View Details" panel, so a Removed action carries its own copy
  // instead. Null for every other action, which still resolve details live.
  snapshot   String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model Appeal {
  id                    String            @id @default(uuid())
  // sourceId points at a Prompt, AiToolRequest, or RiskAlert row depending on
  // sourceType. Prisma can't express a FK to three different tables, so this
  // is validated at the application layer instead of the database layer.
  sourceType            AppealSourceType
  sourceId              String
  userId                String
  user                  User              @relation("AppealFiledBy", fields: [userId], references: [id])
  justification         String
  evidenceUrl           String?
  status                AppealStatus      @default(PENDING)
  resolution            AppealResolution?
  resolutionNotes       String?
  additionalInfoRequest String?
  employeeResponse      String?
  reviewedById          String?
  reviewedBy            User?             @relation("AppealReviewedBy", fields: [reviewedById], references: [id])
  slaDeadline           DateTime?
  createdAt             DateTime          @default(now())
  resolvedAt            DateTime?

  @@map("appeals")
}

model Notification {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  title             String
  message           String
  type              String
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@map("notifications")
}

model PolicyRecommendation {
  id              String               @id @default(uuid())
  title           String
  rationale       String
  department      String?
  confidenceScore Int
  status          RecommendationStatus @default(PENDING)
  generatedAt     DateTime             @default(now())
  reviewedById    String?
  reviewedBy      User?                @relation(fields: [reviewedById], references: [id])
  reviewedAt      DateTime?

  @@map("policy_recommendations")
}

// A conversation with the Governance Copilot — scoped to the admin/compliance
// user who started it, mirroring how AiSession scopes an employee's AI
// Workspace conversations. Kept separate from AiSession/Prompt rather than
// reusing them: those carry sensitive-data detection/sanitization fields and
// an aiToolId FK that don't apply to an internal assistant querying
// already-governed data via function calls.
model GovernanceCopilotSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  startedAt DateTime @default(now())

  messages GovernanceCopilotMessage[]

  @@map("governance_copilot_sessions")
}

model GovernanceCopilotMessage {
  id        String                   @id @default(uuid())
  sessionId String
  session   GovernanceCopilotSession @relation(fields: [sessionId], references: [id])
  role      CopilotRole
  text      String
  createdAt DateTime                 @default(now())

  @@map("governance_copilot_messages")
}
