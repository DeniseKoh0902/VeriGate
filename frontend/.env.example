# Absolute URL of the deployed backend's API, including the /api/v1 prefix.
# Leave unset for local dev — vite.config.ts already proxies /api to
# http://localhost:8001. Only needed when frontend and backend are deployed
# on separate origins (e.g. Vercel + Render).
VITE_API_BASE_URL="https://your-backend.onrender.com/api/v1"
